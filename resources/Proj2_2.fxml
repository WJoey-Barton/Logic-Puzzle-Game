<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Label?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextArea?>


<BorderPane prefHeight="550.0" prefWidth="850.0" 
            xmlns="http://javafx.com/javafx/25" 
            xmlns:fx="http://javafx.com/fxml/1" 
            fx:controller="SceneController">

    <top>
        <Label layoutX="250.0" layoutY="14.0" text="Logic Puzzle Game">
            <BorderPane.margin>
                <Insets top="10" left="10" right="10" bottom="10"/>
            </BorderPane.margin>
        </Label>
    </top>

    <center>
        <GridPane fx:id="squarePane1_GridPane"
                alignment="CENTER"
                hgap="0"
                vgap="0"
                style="-fx-background-color: #f0f0f0;">
        </GridPane>
    </center>

    <right>
        <VBox spacing="10" alignment="TOP_LEFT">
            <Label text="Clues: " />
            <TextArea fx:id="Clue_TextArea" prefWidth="200" wrapText="true" />
            <BorderPane.margin>
                <Insets top="10" left="10" right="10" bottom="10"/>
            </BorderPane.margin>
        </VBox>
    </right>

    <bottom>
        <VBox spacing="10" alignment="CENTER">
            <Label fx:id="Hint_Label" text="HINT: " visible="false" />
            <HBox spacing="10" alignment="CENTER">
                <Button fx:id="Hint_Button" onAction="#HintButton_clicked" text="Hint" />
                <Button fx:id="ClearErrors_Button" onAction="#ClearErrorsButton_clicked" text="Clear Errors" />
                <Button fx:id="StartOver_Button" onAction="#StartOverButton_clicked" text="Start Over" />
                <Button fx:id="SubmitPuzzle_Button" onAction="#SubmitPuzzleButton_clicked" text="Submit Puzzle" visible="false" />
                <BorderPane.margin>
                    <Insets top="10" left="10" right="10" bottom="10"/>
                </BorderPane.margin>
            </HBox>
            <BorderPane.margin>
                <Insets top="10" left="10" right="10" bottom="10"/>
            </BorderPane.margin>
        </VBox>
    </bottom>
</BorderPane>